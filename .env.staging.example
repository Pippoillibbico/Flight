NODE_ENV=production
PORT=3000
TRUST_PROXY=1

FRONTEND_URL=https://staging.example.com
FRONTEND_ORIGIN=https://staging.example.com
CORS_ALLOWLIST=https://staging.example.com

JWT_SECRET=replace-with-staging-secret
OUTBOUND_CLICK_SECRET=replace-with-staging-secret
AUDIT_LOG_HMAC_KEY=replace-with-staging-secret
INTERNAL_INGEST_TOKEN=replace-with-staging-token

DATABASE_URL=postgresql://flight_user:password@staging-db.internal:5432/flight
REDIS_URL=redis://staging-redis.internal:6379/0

BILLING_PROVIDER=stripe
ALLOW_MOCK_BILLING_UPGRADES=false
STRIPE_ALLOW_INLINE_PRICE_DATA=false
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_PUBLISHABLE_KEY=pk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_PRO=price_test_pro_monthly
STRIPE_PRICE_CREATOR=price_test_creator_monthly

AI_ALLOW_FREE_USERS=false
AI_ALLOWED_PLAN_TYPES=elite,creator
AI_BUDGET_GLOBAL_DAILY_CALLS=320
AI_BUDGET_GLOBAL_PER_MINUTE_CALLS=16
AI_BUDGET_USER_DAILY_CALLS=12
AI_BUDGET_ROUTE_DAILY_CALLS=40
AI_BUDGET_GLOBAL_DAILY_EST_TOKENS=220000
AI_BUDGET_USER_DAILY_EST_TOKENS=12000
AI_BUDGET_ROUTE_DAILY_EST_TOKENS=36000
AI_BUDGET_GLOBAL_MONTHLY_EST_TOKENS=3000000
AI_BUDGET_USER_MONTHLY_EST_TOKENS=150000
AI_BUDGET_ROUTE_MONTHLY_EST_TOKENS=380000
AI_BUDGET_FAIL_OPEN=false

ENABLE_PROVIDER_DUFFEL=true
DUFFEL_API_KEY=duffel_test_replace
ENABLE_PROVIDER_KIWI=false
KIWI_TEQUILA_API_KEY=
ENABLE_PROVIDER_SKYSCANNER=false
SKYSCANNER_API_KEY=
LIVE_FLIGHT_DESTINATION_LIMIT=4
PROVIDER_REQUEST_RETRIES=1
PROVIDER_REQUEST_TIMEOUT_MS=12000
PROVIDER_SEARCH_TIMEOUT_MS=12000
PROVIDER_SEARCH_TIMEOUT_MAX_MS=20000
SEARCH_PROVIDER_GLOBAL_DAILY_BUDGET=2500
SEARCH_PROVIDER_USER_DAILY_BUDGET=80
SEARCH_PROVIDER_GLOBAL_PER_MINUTE_BUDGET=120
SEARCH_PROVIDER_ROUTE_DAILY_BUDGET=180
SEARCH_PROVIDER_ROUTE_PER_MINUTE_BUDGET=14
SEARCH_PROVIDER_BUDGET_FAIL_OPEN=false
PRICING_ENABLED=true
MARGIN_GUARD_ENABLED=true
SEARCH_RUNTIME_USER_PER_MINUTE=18
SEARCH_RUNTIME_USER_PER_DAY=220
SEARCH_RUNTIME_SESSION_PER_MINUTE=12
SEARCH_RUNTIME_SESSION_PER_DAY=160
SEARCH_RUNTIME_FREE_USER_PER_MINUTE=4
SEARCH_RUNTIME_FREE_USER_PER_DAY=40
SEARCH_RUNTIME_FREE_SESSION_PER_MINUTE=3
SEARCH_RUNTIME_FREE_SESSION_PER_DAY=30
SEARCH_FREE_LIVE_DESTINATION_LIMIT=1
ENABLE_TRAVELPAYOUTS_AFFILIATE=true
AFFILIATE_TRAVELPAYOUTS_MARKER=tp_marker_replace
SOFT_LAUNCH_PROVIDER_PROFILE=true
SOFT_LAUNCH_AFFILIATE_PROFILE=true
ENABLE_MULTI_SOURCE_SEARCH=false
