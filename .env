PORT=3000
NODE_ENV=development
DATABASE_URL=
# SECURITY: Replace JWT_SECRET with a strong 64+ char random value before deploying to production.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=2e7c4a6b5f90d1c3a8e4b72f9d6c1a3e5f8b0c4d7a2e9f6b1c3d5e7a9b2c4d6f
JWT_ISSUER=flight-suite
JWT_AUDIENCE=flight-suite-web
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
MFA_ISSUER=FlightSuite

SMTP_HOST=
SMTP_PORT=587
# SECURITY: Set to true in production to enforce TLS for SMTP
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Flight Suite <no-reply@example.com>

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_IDS=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID
APPLE_CLIENT_IDS=YOUR_APPLE_CLIENT_ID
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_CLIENT_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_CLIENT_IDS=YOUR_FACEBOOK_APP_ID
FACEBOOK_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
APPLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/apple/callback
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
BOOKING_BASE_URL=https://booking.travel-decision-engine.com/search
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
VITE_APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID
VITE_APPLE_REDIRECT_URI=http://localhost:5173
VITE_FACEBOOK_CLIENT_ID=YOUR_FACEBOOK_APP_ID
OAUTH_SESSION_TTL_SECONDS=300
# SECURITY: Set a strong random HMAC key for audit log integrity verification
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_LOG_HMAC_KEY=REPLACE_WITH_RANDOM_HMAC_KEY_IN_PRODUCTION

CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
NOTIFICATION_CRON=*/10 * * * *

# ── Stripe billing ──────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from https://dashboard.stripe.com/webhooks (after creating a webhook for /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=
# Create products/prices in Stripe dashboard and paste the price IDs here
STRIPE_PRICE_PRO=price_REPLACE_WITH_PRO_PRICE_ID
STRIPE_PRICE_CREATOR=price_REPLACE_WITH_CREATOR_PRICE_ID
