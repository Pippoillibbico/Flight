{
  "name": "flight-suite",
  "version": "3.0.0",
  "private": true,
  "description": "Piattaforma completa ricerca voli: frontend React + backend API",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0 --port 5173 --open /",
    "build": "vite build",
    "lint": "node scripts/lint.mjs",
    "lint:providers": "node scripts/check-no-external-providers.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "backup:postgres": "node scripts/backup-postgres.mjs",
    "ingest:csv": "node scripts/ingest-csv.mjs",
    "import:prices": "node scripts/import-prices.js",
    "worker:price-ingestion": "node scripts/run-worker.mjs price-ingestion",
    "worker:route-baseline": "node scripts/run-worker.mjs route-baseline",
    "worker:discovery-alert": "node scripts/run-worker.mjs discovery-alert",
    "seed:price-observations": "node scripts/seed-price-observations.mjs",
    "test": "node --test --test-concurrency=1 test/**/*.test.mjs",
    "test:smoke": "node --test --test-concurrency=1 test/health-smoke.test.mjs",
    "ci": "npm run lint && npm run lint:providers && npm test && npm run build",
    "test:security": "node scripts/security-smoke.mjs",
    "test:security:compliance": "node scripts/security-compliance.mjs",
    "test:security:gate": "npm run test:security && npm run test:security:compliance",
    "test:go-live": "node scripts/go-live-smoke.mjs",
    "go-live:sequence": "node scripts/go-live-sequence.mjs",
    "preflight:prod": "node scripts/preflight-prod.mjs",
    "show:report": "node scripts/show-report.mjs",
    "slo:report": "node scripts/slo-report.mjs",
    "slo:enforce": "node scripts/slo-report.mjs --enforce",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "node server/index.js",
    "start:prod": "npm run build && node server/index.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "app:start": "powershell -ExecutionPolicy Bypass -File scripts/start-app.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "braintree": "^3.36.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "otplib": "^13.3.0",
    "pg": "^8.19.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "speakeasy": "^2.0.0",
    "world-countries": "^5.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "^5.0.2",
    "vite": "^7.1.3"
  }
}
