PORT=3000
NODE_ENV=development
# Runtime mode for server/index.js:
# - all: API + scheduled workers in one process (default/backward compatible)
# - api: API only (no cron workers)
# - worker: cron workers only (no HTTP listener)
RUNTIME_MODE=all
# DATABASE_URL: PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db).
# When unset, the server uses a local JSON file store (data/*.json) which is NOT suitable
# for production or multi-instance deployments. Set in production.
DATABASE_URL=
# REDIS_URL: Redis connection string (e.g. redis://host:6379 or rediss://host:6380).
# When unset, an in-memory cache is used — NOT shared across instances.
# Required for production horizontal scaling.
REDIS_URL=

# ── SQLite / local storage ─────────────────────────────────────────────────────
# Used only when DATABASE_URL is NOT set (dev / single-instance mode).
# SQLITE_DB_FILE  — custom path for the main application SQLite database.
#                   Defaults to data/flights.db when unset.
# FLIGHT_DB_FILE  — explicit path for the flight data SQLite file (same default).
SQLITE_DB_FILE=
FLIGHT_DB_FILE=data/flights.db
PRICE_HISTORY_DB_FILE=data/price-history.db
# Corruption guard: number of corrupt-DB backups to retain before rotating out.
FLIGHT_DB_CORRUPT_KEEP=5
# Temporary file retention before cleanup (hours). Default: 24.
FLIGHT_DB_TMP_RETENTION_HOURS=24
# Retry settings for atomic file-rename operations on the SQLite file.
FLIGHT_DB_RENAME_RETRIES=4
FLIGHT_DB_RENAME_RETRY_DELAY_MS=35

BUILD_VERSION=3.0.0-local

# ── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL: trace | debug | info | warn | error | fatal
#   Defaults to "debug" in development, "info" in production.
LOG_LEVEL=
# Log file rotation settings (used when writing to disk).
LOG_RETENTION_DAYS=14
LOG_ROTATION_MAX_BYTES=20971520
LOG_ROTATION_INTERVAL_MS=3600000

BODY_JSON_LIMIT=256kb
CORS_ORIGIN=http://localhost:5173
CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=120

# Required: use a long random value (at least 32 chars)
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=flight-suite
JWT_AUDIENCE=flight-suite-web
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
# JWT_EXPIRES_IN: legacy alias — leave empty to use ACCESS_TOKEN_EXPIRES_IN above.
JWT_EXPIRES_IN=
MFA_ISSUER=FlightSuite

# ── App identity & legal pages ─────────────────────────────────────────────────
# Displayed in legal documents (Privacy Policy, Terms of Service, Cookie Notice).
APP_NAME=Flight
LEGAL_COMPANY_NAME=Clariter Group
LEGAL_COMPANY_ADDRESS=Via del Corso 101, 00186 Roma, Italia
LEGAL_PRIVACY_EMAIL=privacy@flightsuite.app
LEGAL_DPO_EMAIL=dpo@flightsuite.app
# ISO date string for policy effective date. Leave empty to use today's date.
LEGAL_EFFECTIVE_DATE=

# ── Registration & legacy auth ─────────────────────────────────────────────────
# AUTH_REGISTRATION_ENABLED / REGISTRATION_ENABLED — set either to "false" to
# close the registration endpoint (e.g. invite-only or maintenance mode).
AUTH_REGISTRATION_ENABLED=true
REGISTRATION_ENABLED=true
# LEGACY_AUTH_ROUTES_ENABLED — enables backward-compatible /api/auth/* routes.
#   Auto-enabled in development, auto-disabled in production unless overridden.
LEGACY_AUTH_ROUTES_ENABLED=
LEGACY_AUTH_RL_PER_MINUTE=12

# Admin backoffice runs as a SEPARATE process (server/backoffice.js) on its own port.
# The main API server (server/index.js) on PORT serves /api/admin/backoffice/report
# to the React SPA. The standalone backoffice HTML dashboard uses BACKOFFICE_PORT.
# Start both separately: node server/index.js && node server/backoffice.js
BACKOFFICE_PORT=3001
ADMIN_BACKOFFICE_PASSWORD=
ADMIN_ALLOWLIST_EMAILS=
# Required in production for server/backoffice.js (use a dedicated strong secret)
BACKOFFICE_JWT_SECRET=replace-with-at-least-32-random-characters
BACKOFFICE_LOGIN_WINDOW_MS=600000
BACKOFFICE_LOGIN_MAX_ATTEMPTS=8
BACKOFFICE_LOGIN_RATE_LIMIT_MAX=12
# Additional backoffice access — comma-separated email addresses beyond ADMIN_ALLOWLIST_EMAILS.
BACKOFFICE_ADMIN_EMAILS=
# Per-user admin credentials in JSON format: {"email@example.com":"hashed_password",...}
# Takes precedence over shared ADMIN_BACKOFFICE_PASSWORD for that user.
BACKOFFICE_ADMIN_CREDENTIALS=
# Set to "true" ONLY in non-production environments to allow shared-password login.
BACKOFFICE_ALLOW_SHARED_PASSWORD_IN_PRODUCTION=false
# Enable X-Forwarded-* header trust for the backoffice process (e.g. "1" behind a proxy).
BACKOFFICE_TRUST_PROXY=

# ── SMTP email ─────────────────────────────────────────────────────────────────
# When SMTP is NOT configured:
#   - New accounts are auto-verified (no email sent). Safe for dev, not for production.
#   - Password reset emails are silently not delivered (the API still returns success).
#   - Price alert notification emails are not sent.
# Set all three (SMTP_HOST, SMTP_USER, SMTP_PASS) together — partial config is ignored.
# Capability: /api/system/capabilities → email_smtp.active
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Flight Suite <no-reply@example.com>

# ── OAuth social login ─────────────────────────────────────────────────────────
# The server checks systemCapabilities.oauth_google / oauth_facebook / oauth_apple
# and returns 503 for any OAuth endpoint whose credentials are not present.
# The React SPA reads /api/system/capabilities and hides buttons for unconfigured providers.
#
# ENABLE_LEGACY_OAUTH_SERVER: enables server.js Facebook-only standalone demo. Leave false.
ENABLE_LEGACY_OAUTH_SERVER=false
OAUTH_STATE_TTL_MS=600000

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Required: GOOGLE_CLIENT_ID (single) OR GOOGLE_CLIENT_IDS (comma-separated list).
# Redirect URI MUST be registered in Google Cloud Console under Authorized redirect URIs.
# Production: https://yourdomain.com/api/auth/oauth/google/callback
# Dev:        http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
# Legacy var (server.js only): use GOOGLE_OAUTH_REDIRECT_URI above for main server
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
# Client-side (Vite): used for Google One Tap. Must match GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=

# ── Facebook OAuth ─────────────────────────────────────────────────────────────
# Required: FACEBOOK_CLIENT_ID (checked by server) OR FACEBOOK_APP_ID (legacy server.js).
# If using the main server (server/index.js), set FACEBOOK_CLIENT_ID.
# If using the legacy standalone server (server.js), set FACEBOOK_APP_ID.
# Redirect URI MUST be registered in Facebook App Dashboard under Valid OAuth Redirect URIs.
# Production: https://yourdomain.com/api/auth/oauth/facebook/callback
# Dev:        http://localhost:3000/api/auth/oauth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_IDS=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
# Legacy vars (server.js only): use FACEBOOK_CLIENT_ID above for main server
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
# Client-side (Vite): used for Facebook JS SDK login flow.
VITE_FACEBOOK_CLIENT_ID=

# ── Apple OAuth ────────────────────────────────────────────────────────────────
# Apple OAuth requires an Apple Developer account ($99/yr).
# All four server-side vars are required to complete a Sign in with Apple flow:
#   APPLE_CLIENT_ID   — Services ID (e.g. com.yourdomain.app.signin), NOT the App Bundle ID
#   APPLE_TEAM_ID     — 10-character Team ID from Apple Developer portal
#   APPLE_KEY_ID      — Key ID of the .p8 private key created for "Sign in with Apple"
#   APPLE_PRIVATE_KEY — Full PEM content of the .p8 key; replace literal newlines with \n
# The button is hidden in the UI when APPLE_CLIENT_ID is not set.
# Redirect URI MUST be registered in Apple Developer Portal under Sign in with Apple.
APPLE_CLIENT_ID=
APPLE_CLIENT_IDS=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/apple/callback
# Client-side (Vite): used for Apple JS Sign In flow.
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=http://localhost:5173

FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
AUTH_COOKIE_DOMAIN=
TRUST_PROXY=1
ALLOW_INSECURE_STARTUP_FOR_TESTS=false
ALLOW_INSECURE_STARTUP_IN_PRODUCTION=false
OAUTH_FETCH_TIMEOUT_MS=8000
BOOKING_BASE_URL=https://booking.travel-decision-engine.com/search
ENABLE_EXTERNAL_FLIGHT_PARTNERS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── AI token cost rates ────────────────────────────────────────────────────────
# Used by the AI pricing automation cron (AI_PRICING_CRON) to estimate monthly
# spend and adjust subscription prices accordingly.  Values are USD per 1M tokens.
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60
ANTHROPIC_INPUT_COST_PER_1M=3
ANTHROPIC_OUTPUT_COST_PER_1M=15

# ── AI response cache (server/lib/ai-cache.js) ────────────────────────────────
# Caches AI API responses (OpenAI + Anthropic) to cut token spend on repeated
# or near-identical inputs.  In-memory by default; backed by Redis when REDIS_URL
# is set.  In-flight deduplication prevents the same prompt firing twice
# concurrently — all waiters share the single in-progress result.
#
# AI_CACHE_ENABLED               — set to "false" to disable caching entirely.
#                                  Default: true.
# AI_ENRICHMENT_CACHE_TTL_SECONDS — TTL for enrichDecisionWithAi results.
#                                  Decision context changes slowly; 2 h is safe.
#                                  Default: 7200 (2 h).
# AI_INTENT_CACHE_TTL_SECONDS    — TTL for parseIntentWithAi results.
#                                  User prompts are idempotent inputs; 24 h cuts
#                                  repeat spend on common search phrases.
#                                  Default: 86400 (24 h).
# AI_CACHE_MEMORY_MAX_ENTRIES    — max entries for local in-memory fallback cache.
#                                  Default: 512.
# AI_ROUTE_DECISION_ENABLED      — enable AI enrichment for /decision/just-go.
# AI_ROUTE_INTENT_ENABLED        — enable AI parsing for /decision/intake.
# AI_ALLOW_FREE_USERS            — allow non-premium plans to call AI routes.
#                                  Default: false (premium-only).
# AI_ALLOWED_PLAN_TYPES          — comma list of plans allowed to use AI.
#                                  Default: elite,creator.
# AI_INTENT_HEURISTIC_CONFIDENCE_SKIP_ENABLED — skip AI when heuristic extraction
#                                  is already strong enough.
# AI_INTENT_HEURISTIC_MIN_SIGNALS — minimum heuristic signals to skip AI.
# AI_INTENT_HEURISTIC_MAX_PROMPT_LENGTH — max prompt length eligible for skip.
# AI_DECISION_CACHE_ONLY_MODE    — when true, decision AI uses cache only and
#                                  never triggers live provider calls on misses.
# AI_INTENT_CACHE_ONLY_MODE      — when true, intent AI uses cache only and
#                                  never triggers live provider calls on misses.
AI_CACHE_ENABLED=true
AI_ENRICHMENT_CACHE_TTL_SECONDS=7200
AI_INTENT_CACHE_TTL_SECONDS=86400
AI_CACHE_MEMORY_MAX_ENTRIES=512
AI_CACHE_DISTRIBUTED_DEDUPE_ENABLED=true
AI_CACHE_DISTRIBUTED_LOCK_TTL_SECONDS=15
AI_CACHE_DISTRIBUTED_WAIT_MS=2500
AI_CACHE_DISTRIBUTED_POLL_MS=120
AI_CACHE_DISTRIBUTED_STRICT_WAIT=false
AI_ROUTE_DECISION_ENABLED=true
AI_ROUTE_INTENT_ENABLED=true
AI_ALLOW_FREE_USERS=false
AI_ALLOWED_PLAN_TYPES=elite,creator
AI_INTENT_HEURISTIC_CONFIDENCE_SKIP_ENABLED=true
AI_INTENT_HEURISTIC_MIN_SIGNALS=3
AI_INTENT_HEURISTIC_MAX_PROMPT_LENGTH=280
AI_DECISION_CACHE_ONLY_MODE=false
AI_INTENT_CACHE_ONLY_MODE=false
OPENAI_MODEL_DECISION=
OPENAI_MODEL_INTENT=
ANTHROPIC_MODEL_DECISION=
ANTHROPIC_MODEL_INTENT=
AI_MAX_PROMPT_CHARS_DECISION=3600
AI_MAX_PROMPT_CHARS_INTENT=1200
AI_EST_INPUT_TOKENS_DECISION=420
AI_EST_OUTPUT_TOKENS_DECISION=180
AI_EST_INPUT_TOKENS_INTENT=220
AI_EST_OUTPUT_TOKENS_INTENT=120
AI_BUDGET_GLOBAL_DAILY_CALLS=320
AI_BUDGET_GLOBAL_PER_MINUTE_CALLS=16
AI_BUDGET_USER_DAILY_CALLS=12
AI_BUDGET_ROUTE_DAILY_CALLS=40
AI_BUDGET_GLOBAL_DAILY_EST_TOKENS=220000
AI_BUDGET_USER_DAILY_EST_TOKENS=12000
AI_BUDGET_ROUTE_DAILY_EST_TOKENS=36000
AI_BUDGET_GLOBAL_MONTHLY_EST_TOKENS=3000000
AI_BUDGET_USER_MONTHLY_EST_TOKENS=150000
AI_BUDGET_ROUTE_MONTHLY_EST_TOKENS=380000
AI_BUDGET_FAIL_OPEN=false

# ── Billing (Stripe only) ──────────────────────────────────────────────────────
# BILLING_PROVIDER accepts only 'stripe'. Any other value fails runtime config checks.
# The /api/system/capabilities endpoint exposes billing.active so the UI can gate upgrade flows.
# ALLOW_MOCK_BILLING_UPGRADES=true enables demo upgrade routes — MUST be false in production.
BILLING_PROVIDER=stripe
ALLOW_MOCK_BILLING_UPGRADES=false

# ── Stripe billing ─────────────────────────────────────────────────────────────
# Required when BILLING_PROVIDER=stripe.
# STRIPE_SECRET_KEY: starts with sk_live_ (prod) or sk_test_ (dev). Min 16 chars.
# STRIPE_PUBLISHABLE_KEY: starts with pk_live_ (prod) or pk_test_ (dev). Safe for frontend exposure.
# STRIPE_WEBHOOK_SECRET: starts with whsec_. REQUIRED IN PRODUCTION when STRIPE_SECRET_KEY is set.
#   Create at: Dashboard → Developers → Webhooks → Add endpoint.
#   Events to listen to: customer.subscription.created/updated/deleted, invoice.payment_succeeded/failed
# STRIPE_PRICE_PRO: Stripe Price ID for PRO monthly subscription (e.g. price_xxxxxxxx).
# STRIPE_PRICE_CREATOR: Stripe Price ID for ELITE monthly subscription (e.g. price_xxxxxxxx).
# STRIPE_SUBSCRIPTION_PRORATION_BEHAVIOR: default behavior for backend plan changes
#   allowed: create_prorations | none | always_invoice (default create_prorations).
# STRIPE_ALLOW_INLINE_PRICE_DATA: set true only for local/dev fallback when price IDs are missing.
#   keep false in production (recommended).
# STRIPE_PRICE_LOOKUP_KEY_PRO / STRIPE_PRICE_LOOKUP_KEY_CREATOR:
#   optional keys used by `npm run billing:stripe:sync-plans` when creating/finding Stripe prices.
# STRIPE_PRICE_CURRENCY: currency for sync script (default EUR).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CREATOR=
STRIPE_SUBSCRIPTION_PRORATION_BEHAVIOR=create_prorations
STRIPE_ALLOW_INLINE_PRICE_DATA=false
STRIPE_PRICE_LOOKUP_KEY_PRO=flight_pro_monthly
STRIPE_PRICE_LOOKUP_KEY_CREATOR=flight_creator_monthly
STRIPE_PRICE_CURRENCY=EUR

# ── Subscription plan price overrides ─────────────────────────────────────────
# When set, these override the hardcoded PLANS constants in saas-db.js and are
# served by GET /api/billing/pricing.  The frontend reads this endpoint and uses
# the values as the source of truth for displayed prices.
# Leave empty to use the defaults: free=0, pro=12.99, creator=29.99 (EUR).
PRICING_FREE_EUR=
PRICING_PRO_EUR=
PRICING_CREATOR_EUR=

# Max active price alerts allowed for Pro plan users (Elite = unlimited).
SMART_ALERTS_PRO_LIMIT=3

# Premium trial duration in days granted to new registrations (0 = disabled).
PREMIUM_TRIAL_DAYS=0

# Legacy Braintree variables removed (Stripe-only billing).

# Comma-separated email addresses that get admin access in the React SPA.
# If not set, NO user will have admin access (the default allowlist is empty).
# Example: VITE_ADMIN_ALLOWLIST_EMAILS=owner@yourdomain.com,ops@yourdomain.com
VITE_ADMIN_ALLOWLIST_EMAILS=
OAUTH_SESSION_TTL_SECONDS=300
AUDIT_LOG_HMAC_KEY=
AUDIT_LOG_FILE=data/audit-log.ndjson
# Distributed locking for concurrent audit-log writes (Redis-backed).
AUDIT_LOG_LOCK_WAIT_MS=2000
AUDIT_LOG_LOCK_STALE_MS=30000
AUDIT_LOG_LOCK_POLL_MS=75

# ── Outbound / affiliate links ─────────────────────────────────────────────────
# OUTBOUND_CLICK_SECRET: HMAC secret for signing outbound affiliate click tokens.
#   When empty, click tracking tokens are unsigned (OK for dev; set in production).
OUTBOUND_CLICK_SECRET=
OUTBOUND_CLICK_TTL_SECONDS=300

# Comma-separated list of allowed web origins for API CORS
OUTBOUND_ALLOWED_HOSTS=

# ── Affiliate partner IDs ──────────────────────────────────────────────────────
# Used by server/lib/affiliate-links.js to generate tracked booking links.
# Leave empty to disable that partner's affiliate tracking.
# Default affiliate partner when no specific provider is configured.
# tde_booking = internal fallback (no commission, always works).
# Set to 'travelpayouts', 'kiwi', or 'skyscanner' only after configuring
# the corresponding credentials below.
AFFILIATE_DEFAULT_PARTNER=tde_booking
AFFILIATE_SITE_NAME=flightsuite
# ── Travelpayouts (recommended near-term channel) ──────────────────────────────
# Join at https://travelpayouts.com/ — no commercial agreement required.
# Once you have a marker token, set it here and change AFFILIATE_DEFAULT_PARTNER=travelpayouts.
# Links target Aviasales (Travelpayouts' flagship product, includes Kiwi inventory).
# Commission: ~1.8% CPA (varies by sub-affiliate program).
ENABLE_TRAVELPAYOUTS_AFFILIATE=true
AFFILIATE_TRAVELPAYOUTS_MARKER=
# ── Kiwi.com direct affiliate (requires commercial partner account) ────────────
# Only set this if you have a Kiwi affiliate account (separate from Tequila API).
# https://www.kiwi.com/us/pages/partner-program
AFFILIATE_KIWI_ID=
# ── Skyscanner (requires Partners agreement) ──────────────────────────────────
AFFILIATE_SKYSCANNER_ID=
AFFILIATE_BOOKING_AID=

# HTTP rate-limits
RL_API_PER_MINUTE=120
RL_DEMO_PER_MINUTE=40
RL_AUTH_PER_MINUTE=15
RL_LOGIN_ATTEMPTS_15M=12
RL_OUTBOUND_PER_MINUTE=120
RL_OUTBOUND_PER_SECOND=10
RL_TELEMETRY_PER_SECOND=10
RL_TELEMETRY_PER_MINUTE=80
AUTH_REQUIRE_TRUSTED_ORIGIN=true
AUTH_RETURN_ACCESS_TOKEN=false
REQUEST_LOG_SUCCESS_SAMPLE_RATE=0.2
REQUEST_LOG_SLOW_MS=1200
REQUEST_LOG_EXPECTED_5XX_ENDPOINT_PREFIXES=/api/health/deploy-readiness

# API payload hardening
API_MAX_BODY_BYTES=65536
AUTH_MAX_BODY_BYTES=12288
OUTBOUND_MAX_BODY_BYTES=16384
OUTBOUND_MAX_QUERY_CHARS=1600
PAYLOAD_MAX_DEPTH=8
PAYLOAD_MAX_NODES=600
PAYLOAD_MAX_ARRAY_LENGTH=250
PAYLOAD_MAX_OBJECT_KEYS=250
PAYLOAD_MAX_STRING_LENGTH=8192
PAYLOAD_MAX_KEY_LENGTH=96
ADMIN_TELEMETRY_BURST_WINDOW_MS=10000
ADMIN_TELEMETRY_BURST_MAX=4
# Max body bytes accepted for admin telemetry POST requests. Default: 8192.
ADMIN_TELEMETRY_MAX_BODY_BYTES=8192
# Max allowed clock skew (ms) between client and server for telemetry timestamps.
ADMIN_TELEMETRY_ALLOWED_SKEW_MS=86400000
# Deduplication window for identical consecutive telemetry events (ms). Default: 2500.
TELEMETRY_DEDUPE_WINDOW_MS=2500
# Set to "false" to disable the /api/admin/dashboard endpoint entirely.
ADMIN_DASHBOARD_ENABLED=true
LOG_HASH_SALT=

# Password reset (frontend URL where ?reset_token=... is handled)
PASSWORD_RESET_URL=http://localhost:5173

# Email verification (frontend URL where ?verify_token=... is handled)
# When SMTP is not configured, new accounts are auto-verified without sending an email.
EMAIL_VERIFY_URL=http://localhost:5173

# Background scan cadence for alert subscriptions (cron syntax)
NOTIFICATION_CRON=*/10 * * * *

# AI pricing automation (ChatGPT + Claude token costs)
# Every day at 00:00 and 08:00 by default
AI_PRICING_CRON=0 0,8 * * *
AI_PRICING_CRON_TIMEZONE=Europe/Rome
AI_COST_FEED_URL=
AI_TARGET_MARGIN=0.72
AI_USAGE_GROWTH_FACTOR=1.15
AI_PLATFORM_OVERHEAD_EUR=2.2
AI_SAFETY_BUFFER_EUR=1.4

# Free plan backend foundation (no real-time LLM for FREE)
# Data export (GET /api/user/data-export[.csv]) is quota-gated per plan:
#   Free plan:    export quota = 0 (endpoint returns 403 upgrade_required)
#   Pro plan:     export quota = 0 (same)
#   Creator plan: export quota = 400/month (fully operational)
IP_HASH_SALT=replace-with-random-salt
FREE_DAILY_SEARCH_LIMIT=100
FREE_ACTIVE_ALERT_LIMIT=5
DEMO_DAILY_SEARCH_LIMIT=15
DEMO_MINUTE_IP_LIMIT=20
DEMO_MINUTE_DEVICE_LIMIT=30
FREE_USER_MINUTE_LIMIT=60
FREE_PRECOMPUTE_CRON=20 2 * * *
FREE_ALERT_WORKER_CRON=*/15 * * * *
FREE_JOBS_TIMEZONE=UTC

# ── Background worker schedules ────────────────────────────────────────────────
# Price ingest worker: fetches and stores raw price data from providers.
PRICE_INGEST_WORKER_CRON=*/5 * * * *
PRICE_INGEST_WORKER_TIMEZONE=UTC
# Radar match precompute: pre-scores user/destination affinity pairs.
RADAR_MATCH_PRECOMPUTE_CRON=*/40 * * * *
RADAR_MATCH_PRECOMPUTE_TIMEZONE=UTC

# Internal proprietary ingestion + route baselines
INTERNAL_INGEST_TOKEN=replace-with-long-random-token
DISCOVERY_ALERT_WORKER_CRON=*/20 * * * *
DISCOVERY_ALERT_WORKER_TIMEZONE=UTC
# Default origin IATA shown in the discovery feed when the caller does not
# specify one (e.g. unauthenticated or missing home airport). Default: FCO.
DEFAULT_DISCOVERY_ORIGIN=FCO
# TTL for the /api/discovery route-level HTTP response cache (seconds).
# Distinct from DISCOVERY_FEED_CACHE_TTL_SEC which governs the feed engine's
# internal Redis cache. Default: 75.
DISCOVERY_API_CACHE_TTL_SEC=75
DISCOVERY_FEED_CACHE_TTL_SEC=90
DISCOVERY_FEED_VERSION_CACHE_TTL_SEC=20
# In-memory LRU cap for the discovery feed cache (number of entries). Default: 300.
DISCOVERY_FEED_CACHE_MAX_ENTRIES=300
# A/B test for feed ranking algorithm. When enabled, users are bucketed by HMAC
# of their ID into control (original scoring) and variant (experimental scoring).
DISCOVERY_FEED_RANKING_AB_ENABLED=false
DISCOVERY_FEED_RANKING_AB_SPLIT_PCT=50
DISCOVERY_FEED_RANKING_AB_SALT=discovery_feed_rank_ab_v1
DISCOVERY_FEED_LAST_MINUTE_DAYS=14
DISCOVERY_FEED_LONG_HAUL_MIN_DISTANCE_KM=3500
DISCOVERY_FEED_LONG_HAUL_MIN_DURATION_MIN=420
DISCOVERY_FEED_LONG_HAUL_MIN_SAVINGS_PCT=10
DISCOVERY_FEED_MIN_PRICE=10
DISCOVERY_FEED_MAX_PRICE=20000
DISCOVERY_FEED_MAX_AGE_HOURS=168
DISCOVERY_FEED_STALE_FALLBACK_ENABLED=true
DISCOVERY_FEED_STALE_FALLBACK_MAX_AGE_HOURS=168
DISCOVERY_FEED_ALLOW_CANDIDATE_FALLBACK=false
DISCOVERY_FEED_MAX_STOPS=3
DISCOVERY_FEED_MIN_DURATION_MIN=30
DISCOVERY_FEED_MAX_DURATION_MIN=2160
DISCOVERY_FEED_NEAR_DUP_PRICE_DELTA_PCT=3
DISCOVERY_FEED_NEAR_DUP_MAX_PER_CLUSTER=2
DISCOVERY_FEED_MAX_PER_DESTINATION=3
DEAL_BASELINE_CRON=10 1 * * *
DEAL_BASELINE_CRON_TIMEZONE=UTC
PROVIDER_COLLECTION_ENABLED=false
SCAN_PROVIDER_OVERLAP_POLICY=mutual_exclusive
PROVIDER_COLLECTION_ALLOW_WITH_SCAN=false
