PORT=3000
NODE_ENV=development
DATABASE_URL=
REDIS_URL=
BUILD_VERSION=3.0.0-local
BODY_JSON_LIMIT=256kb
CORS_ORIGIN=http://localhost:5173
CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=120

# Required: use a long random value (at least 32 chars)
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=flight-suite
JWT_AUDIENCE=flight-suite-web
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
MFA_ISSUER=FlightSuite

# SMTP email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Flight Suite <no-reply@example.com>

# OAuth social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_IDS=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_IDS=
FACEBOOK_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
AUTH_COOKIE_DOMAIN=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
APPLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/apple/callback
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
OAUTH_FETCH_TIMEOUT_MS=8000
BOOKING_BASE_URL=https://booking.travel-decision-engine.com/search
ENABLE_EXTERNAL_FLIGHT_PARTNERS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CREATOR=

# Vite client-side public config
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=http://localhost:5173
VITE_FACEBOOK_CLIENT_ID=
OAUTH_SESSION_TTL_SECONDS=300
AUDIT_LOG_HMAC_KEY=

# Comma-separated list of allowed web origins for API CORS
OUTBOUND_ALLOWED_HOSTS=

# HTTP rate-limits
RL_API_PER_MINUTE=120
RL_DEMO_PER_MINUTE=40
RL_AUTH_PER_MINUTE=15
RL_LOGIN_ATTEMPTS_15M=12

# Password reset
PASSWORD_RESET_URL=http://localhost:5173

# Background scan cadence for alert subscriptions (cron syntax)
NOTIFICATION_CRON=*/10 * * * *

# AI pricing automation (ChatGPT + Claude token costs)
# Every day at 00:00 and 08:00 by default
AI_PRICING_CRON=0 0,8 * * *
AI_PRICING_CRON_TIMEZONE=Europe/Rome
AI_COST_FEED_URL=
AI_TARGET_MARGIN=0.72
AI_USAGE_GROWTH_FACTOR=1.15
AI_PLATFORM_OVERHEAD_EUR=2.2
AI_SAFETY_BUFFER_EUR=1.4

# Free plan backend foundation (no real-time LLM for FREE)
IP_HASH_SALT=replace-with-random-salt
FREE_DAILY_SEARCH_LIMIT=100
FREE_ACTIVE_ALERT_LIMIT=5
DEMO_DAILY_SEARCH_LIMIT=15
DEMO_MINUTE_IP_LIMIT=20
DEMO_MINUTE_DEVICE_LIMIT=30
FREE_USER_MINUTE_LIMIT=60
FREE_PRECOMPUTE_CRON=20 2 * * *
FREE_ALERT_WORKER_CRON=*/15 * * * *
FREE_JOBS_TIMEZONE=UTC

# Internal proprietary ingestion + route baselines
INTERNAL_INGEST_TOKEN=replace-with-long-random-token
DISCOVERY_ALERT_WORKER_CRON=*/20 * * * *
DISCOVERY_ALERT_WORKER_TIMEZONE=UTC
DEAL_BASELINE_CRON=10 1 * * *
DEAL_BASELINE_CRON_TIMEZONE=UTC
PROVIDER_COLLECTION_ENABLED=false
PROVIDER_COLLECTION_CRON=17 * * * *
PROVIDER_COLLECTION_TIMEZONE=UTC
PROVIDER_COLLECTION_LIMIT_ROUTES=200
PROVIDER_COLLECTION_HORIZON_DAYS=180
PROVIDER_COLLECTION_CONCURRENCY=5
BOOTSTRAP_SEED_IMPORT_FILE=
BOOTSTRAP_SEED_IMPORT_DRY_RUN=false
ENABLE_PROVIDER_DUFFEL=false
ENABLE_PROVIDER_AMADEUS=false
DUFFEL_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
CRON_RETRY_ATTEMPTS=1
CRON_RETRY_DELAY_MS=1500
SHUTDOWN_TIMEOUT_MS=12000
