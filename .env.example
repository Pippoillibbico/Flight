# Regression intelligence gates
TEST_INTELLIGENCE_SKIP_E2E=false
TEST_INTELLIGENCE_TEST_ISOLATION_NONE=false
TEST_INTELLIGENCE_ALLOW_E2E_SPAWN_EPERM_SKIP=true

# Ingestion jobs maintenance
INGESTION_JOBS_RETENTION_DAYS=30
INGESTION_JOBS_RETENTION_MAX_ROWS=5000
INGESTION_JOBS_CLEANUP_MIN_INTERVAL_MS=900000
INGESTION_JOBS_STALE_RUNNING_HOURS=6
INGESTION_JOBS_SAME_TYPE_STALE_MINUTES=60
INGESTION_JOB_OVERLAP_GUARD_MINUTES=30
INGESTION_JOBS_MAINTENANCE_CRON=*/15 * * * *
INGESTION_JOBS_MAINTENANCE_TIMEZONE=UTC

# System state report guardrails
SYSTEM_STATE_REPORT_REQUIRE_PRIMARY=false

# ── Data retention ─────────────────────────────────────────────────────────────
# Controls automatic cleanup of old records in the local SQLite store.
# _DAYS: records older than this are eligible for deletion.
# _MAX:  hard cap on total rows — oldest records deleted first if exceeded.
DATA_RETENTION_AUTH_EVENTS_DAYS=180
DATA_RETENTION_AUTH_EVENTS_MAX=3000
DATA_RETENTION_CLIENT_TELEMETRY_DAYS=120
DATA_RETENTION_CLIENT_TELEMETRY_MAX=12000
DATA_RETENTION_OUTBOUND_EVENTS_DAYS=180
DATA_RETENTION_OUTBOUND_EVENTS_MAX=5000

# ── Startup & subscription scan ────────────────────────────────────────────────
# RUN_STARTUP_TASKS — run DB cleanup and index-build tasks on process start.
RUN_STARTUP_TASKS=true
# SUBSCRIPTION_SCAN_CACHE_TTL_SEC / LOCK_TTL_SEC — control the distributed scan
# that verifies Stripe subscription states at startup and on a schedule.
SUBSCRIPTION_SCAN_CACHE_TTL_SEC=900
SUBSCRIPTION_SCAN_LOCK_TTL_SEC=300

# ── Deal engine admin ──────────────────────────────────────────────────────────
# ENGINE_ADMIN_KEY: secret token required for internal deal-engine admin endpoints.
# Leave empty to disable those endpoints. Use a long random value in production.
ENGINE_ADMIN_KEY=

# ── Pricing engine (server/lib/pricing-engine.js) ─────────────────────────────
# Controls the markup applied to every raw Duffel price before it reaches the
# frontend.  The frontend NEVER sees the raw provider cost — only displayPrice.
#
# PRICING_ENABLED          — set to "false" to pass through raw prices unchanged
#                            (killswitch for migration / A-B testing). Default: true.
# PRICING_BASE_MARGIN_RATE — flat percentage added on top of provider cost.
#                            Covers net margin + partial Stripe + AI overhead.
#                            Default: 0.08 (8%).
# PRICING_MIN_ABSOLUTE_MARGIN_EUR — minimum margin in EUR regardless of %.
#                            Protects very cheap fares.  Default: 4.50.
# PRICING_MAX_ABSOLUTE_MARGIN_EUR — cap to avoid over-charging expensive tickets.
#                            Default: 80.
# PRICING_STRIPE_FEE_RATE  — estimated Stripe % fee baked into the margin.
#                            Default: 0.029 (2.9%).
# PRICING_STRIPE_FEE_FIXED_EUR — Stripe fixed fee per transaction. Default: 0.30.
# PRICING_AI_COST_PER_REQUEST_EUR — AI overhead amortised per priced offer.
#                            Default: 0.10.
# PRICING_LAST_MINUTE_DAYS — departure within this many days triggers +2% adder.
#                            Default: 7.
PRICING_ENABLED=true
PRICING_BASE_MARGIN_RATE=0.08
PRICING_MIN_ABSOLUTE_MARGIN_EUR=4.50
PRICING_MAX_ABSOLUTE_MARGIN_EUR=80
PRICING_STRIPE_FEE_RATE=0.029
PRICING_STRIPE_FEE_FIXED_EUR=0.30
PRICING_AI_COST_PER_REQUEST_EUR=0.10
PRICING_LAST_MINUTE_DAYS=7

# ── Margin guard (server/lib/margin-guard.js) ─────────────────────────────────
# Second-pass economic protection layer that runs AFTER the pricing engine.
# Catches edge cases where the computed displayPrice still does not cover all
# costs (config drift, disabled engine, discounts applied downstream, etc.).
#
# MARGIN_GUARD_ENABLED     — set to "false" to disable all checks (emergency
#                            killswitch only). Default: true.
# MARGIN_GUARD_ACTION      — what to do when an offer fails the margin check:
#                              recalculate — adjust price to minimum viable value (default)
#                              exclude     — mark offer as non-bookable
# MARGIN_MIN_NET_EUR       — minimum acceptable net margin in EUR. Default: 3.00.
# MARGIN_MIN_NET_RATE      — minimum net margin as fraction of revenue. Default: 0.03 (3%).
# MARGIN_DUFFEL_COST_BUFFER_RATE — safety buffer on top of raw Duffel cost to
#                            absorb Duffel's own fee fluctuations. Default: 0.005 (0.5%).
# MARGIN_STRIPE_FEE_RATE   — Stripe % fee used in guard P&L model. Default: 0.029.
# MARGIN_STRIPE_FEE_FIXED_EUR — Stripe fixed fee used in guard P&L model. Default: 0.30.
# MARGIN_AI_COST_PER_TRANSACTION_EUR — AI cost per offer validation. Default: 0.10.
# MARGIN_MAX_VIABLE_PRICE_MULTIPLIER — if the minimum viable recalculated price
#                            exceeds providerCost × this multiplier, the offer is
#                            excluded instead of recalculated. Default: 2.5.
MARGIN_GUARD_ENABLED=true
MARGIN_GUARD_ACTION=recalculate
MARGIN_MIN_NET_EUR=3.00
MARGIN_MIN_NET_RATE=0.03
MARGIN_DUFFEL_COST_BUFFER_RATE=0.005
MARGIN_STRIPE_FEE_RATE=0.029
MARGIN_STRIPE_FEE_FIXED_EUR=0.30
MARGIN_AI_COST_PER_TRANSACTION_EUR=0.10
MARGIN_MAX_VIABLE_PRICE_MULTIPLIER=2.5
