PORT=3000
NODE_ENV=development
# DATABASE_URL: PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db).
# When unset, the server uses a local JSON file store (data/*.json) which is NOT suitable
# for production or multi-instance deployments. Set in production.
DATABASE_URL=
# REDIS_URL: Redis connection string (e.g. redis://host:6379 or rediss://host:6380).
# When unset, an in-memory cache is used — NOT shared across instances.
# Required for production horizontal scaling.
REDIS_URL=
BUILD_VERSION=3.0.0-local
BODY_JSON_LIMIT=256kb
CORS_ORIGIN=http://localhost:5173
CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=120

# Required: use a long random value (at least 32 chars)
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=flight-suite
JWT_AUDIENCE=flight-suite-web
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
MFA_ISSUER=FlightSuite
# Admin backoffice runs as a SEPARATE process (server/backoffice.js) on its own port.
# The main API server (server/index.js) on PORT serves /api/admin/backoffice/report
# to the React SPA. The standalone backoffice HTML dashboard uses BACKOFFICE_PORT.
# Start both separately: node server/index.js && node server/backoffice.js
BACKOFFICE_PORT=3001
ADMIN_BACKOFFICE_PASSWORD=
ADMIN_ALLOWLIST_EMAILS=
# Required in production for server/backoffice.js (use a dedicated strong secret)
BACKOFFICE_JWT_SECRET=replace-with-at-least-32-random-characters
BACKOFFICE_LOGIN_WINDOW_MS=600000
BACKOFFICE_LOGIN_MAX_ATTEMPTS=8
BACKOFFICE_LOGIN_RATE_LIMIT_MAX=12

# ── SMTP email ─────────────────────────────────────────────────────────────────
# When SMTP is NOT configured:
#   - New accounts are auto-verified (no email sent). Safe for dev, not for production.
#   - Password reset emails are silently not delivered (the API still returns success).
#   - Price alert notification emails are not sent.
# Set all three (SMTP_HOST, SMTP_USER, SMTP_PASS) together — partial config is ignored.
# Capability: /api/system/capabilities → email_smtp.active
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Flight Suite <no-reply@example.com>

# ── OAuth social login ─────────────────────────────────────────────────────────
# The server checks systemCapabilities.oauth_google / oauth_facebook / oauth_apple
# and returns 503 for any OAuth endpoint whose credentials are not present.
# The React SPA reads /api/system/capabilities and hides buttons for unconfigured providers.
#
# ENABLE_LEGACY_OAUTH_SERVER: enables server.js Facebook-only standalone demo. Leave false.
ENABLE_LEGACY_OAUTH_SERVER=false
OAUTH_STATE_TTL_MS=600000

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Required: GOOGLE_CLIENT_ID (single) OR GOOGLE_CLIENT_IDS (comma-separated list).
# Redirect URI MUST be registered in Google Cloud Console under Authorized redirect URIs.
# Production: https://yourdomain.com/api/auth/oauth/google/callback
# Dev:        http://localhost:3000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
# Legacy var (server.js only): use GOOGLE_OAUTH_REDIRECT_URI above for main server
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
# Client-side (Vite): used for Google One Tap. Must match GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=

# ── Facebook OAuth ─────────────────────────────────────────────────────────────
# Required: FACEBOOK_CLIENT_ID (checked by server) OR FACEBOOK_APP_ID (legacy server.js).
# If using the main server (server/index.js), set FACEBOOK_CLIENT_ID.
# If using the legacy standalone server (server.js), set FACEBOOK_APP_ID.
# Redirect URI MUST be registered in Facebook App Dashboard under Valid OAuth Redirect URIs.
# Production: https://yourdomain.com/api/auth/oauth/facebook/callback
# Dev:        http://localhost:3000/api/auth/oauth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_IDS=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
# Legacy vars (server.js only): use FACEBOOK_CLIENT_ID above for main server
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/oauth/facebook/callback
# Client-side (Vite): used for Facebook JS SDK login flow.
VITE_FACEBOOK_CLIENT_ID=

# ── Apple OAuth ────────────────────────────────────────────────────────────────
# Apple OAuth requires an Apple Developer account ($99/yr).
# All four server-side vars are required to complete a Sign in with Apple flow:
#   APPLE_CLIENT_ID   — Services ID (e.g. com.yourdomain.app.signin), NOT the App Bundle ID
#   APPLE_TEAM_ID     — 10-character Team ID from Apple Developer portal
#   APPLE_KEY_ID      — Key ID of the .p8 private key created for "Sign in with Apple"
#   APPLE_PRIVATE_KEY — Full PEM content of the .p8 key; replace literal newlines with \n
# The button is hidden in the UI when APPLE_CLIENT_ID is not set.
# Redirect URI MUST be registered in Apple Developer Portal under Sign in with Apple.
APPLE_CLIENT_ID=
APPLE_CLIENT_IDS=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/oauth/apple/callback
# Client-side (Vite): used for Apple JS Sign In flow.
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=http://localhost:5173

FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
AUTH_COOKIE_DOMAIN=
TRUST_PROXY=1
ALLOW_INSECURE_STARTUP_FOR_TESTS=false
ALLOW_INSECURE_STARTUP_IN_PRODUCTION=false
OAUTH_FETCH_TIMEOUT_MS=8000
BOOKING_BASE_URL=https://booking.travel-decision-engine.com/search
ENABLE_EXTERNAL_FLIGHT_PARTNERS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ── Billing ────────────────────────────────────────────────────────────────────
# BILLING_PROVIDER: 'braintree' (default in production) or 'stripe' (default in dev).
# Set explicitly to avoid the implicit default. In production, Braintree is required.
# The /api/system/capabilities endpoint exposes billing.active so the UI can gate upgrade flows.
# ALLOW_MOCK_BILLING_UPGRADES=true enables demo upgrade routes — MUST be false in production.
BILLING_PROVIDER=braintree
ALLOW_MOCK_BILLING_UPGRADES=false

# ── Stripe billing ─────────────────────────────────────────────────────────────
# Required when BILLING_PROVIDER=stripe.
# STRIPE_SECRET_KEY: starts with sk_live_ (prod) or sk_test_ (dev). Min 16 chars.
# STRIPE_WEBHOOK_SECRET: starts with whsec_. REQUIRED IN PRODUCTION when STRIPE_SECRET_KEY is set.
#   Create at: Dashboard → Developers → Webhooks → Add endpoint.
#   Events to listen to: customer.subscription.created/updated/deleted, invoice.payment_succeeded/failed
# STRIPE_PRICE_PRO: Stripe Price ID for PRO monthly subscription (e.g. price_xxxxxxxx).
# STRIPE_PRICE_CREATOR: Stripe Price ID for ELITE monthly subscription (e.g. price_xxxxxxxx).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CREATOR=

# ── Braintree billing ──────────────────────────────────────────────────────────
# Required when BILLING_PROVIDER=braintree (default in production).
# All three keys (BT_MERCHANT_ID, BT_PUBLIC_KEY, BT_PRIVATE_KEY) are required together.
# BT_ENVIRONMENT: 'sandbox' for testing, 'production' for live payments.
# BT_PLAN_PRO_ID: Braintree Subscription Plan ID for PRO tier.
#   Create at: Control Panel → Recurring Billing → Plans → New Plan.
# BT_PLAN_CREATOR_ID: Braintree Subscription Plan ID for ELITE tier.
#   Create at: same location as above.
# Without BT_PLAN_PRO_ID and BT_PLAN_CREATOR_ID, subscription checkout will fail at runtime
# even when credentials are present.
BT_ENVIRONMENT=sandbox
BT_MERCHANT_ID=
BT_PUBLIC_KEY=
BT_PRIVATE_KEY=
BT_PLAN_PRO_ID=
BT_PLAN_CREATOR_ID=

# Comma-separated email addresses that get admin access in the React SPA.
# If not set, NO user will have admin access (the default allowlist is empty).
# Example: VITE_ADMIN_ALLOWLIST_EMAILS=owner@yourdomain.com,ops@yourdomain.com
VITE_ADMIN_ALLOWLIST_EMAILS=
OAUTH_SESSION_TTL_SECONDS=300
AUDIT_LOG_HMAC_KEY=
AUDIT_LOG_FILE=data/audit-log.ndjson

# Comma-separated list of allowed web origins for API CORS
OUTBOUND_ALLOWED_HOSTS=

# HTTP rate-limits
RL_API_PER_MINUTE=120
RL_DEMO_PER_MINUTE=40
RL_AUTH_PER_MINUTE=15
RL_LOGIN_ATTEMPTS_15M=12
RL_OUTBOUND_PER_MINUTE=120
RL_OUTBOUND_PER_SECOND=10
RL_TELEMETRY_PER_SECOND=10
AUTH_REQUIRE_TRUSTED_ORIGIN=true
AUTH_RETURN_ACCESS_TOKEN=false
REQUEST_LOG_SUCCESS_SAMPLE_RATE=0.2
REQUEST_LOG_SLOW_MS=1200
REQUEST_LOG_EXPECTED_5XX_ENDPOINT_PREFIXES=/api/health/deploy-readiness

# API payload hardening
API_MAX_BODY_BYTES=65536
AUTH_MAX_BODY_BYTES=12288
OUTBOUND_MAX_BODY_BYTES=16384
OUTBOUND_MAX_QUERY_CHARS=1600
PAYLOAD_MAX_DEPTH=8
PAYLOAD_MAX_NODES=600
PAYLOAD_MAX_ARRAY_LENGTH=250
PAYLOAD_MAX_OBJECT_KEYS=250
PAYLOAD_MAX_STRING_LENGTH=8192
PAYLOAD_MAX_KEY_LENGTH=96
ADMIN_TELEMETRY_BURST_WINDOW_MS=10000
ADMIN_TELEMETRY_BURST_MAX=4
LOG_HASH_SALT=

# Password reset (frontend URL where ?reset_token=... is handled)
PASSWORD_RESET_URL=http://localhost:5173

# Email verification (frontend URL where ?verify_token=... is handled)
# When SMTP is not configured, new accounts are auto-verified without sending an email.
EMAIL_VERIFY_URL=http://localhost:5173

# Background scan cadence for alert subscriptions (cron syntax)
NOTIFICATION_CRON=*/10 * * * *

# AI pricing automation (ChatGPT + Claude token costs)
# Every day at 00:00 and 08:00 by default
AI_PRICING_CRON=0 0,8 * * *
AI_PRICING_CRON_TIMEZONE=Europe/Rome
AI_COST_FEED_URL=
AI_TARGET_MARGIN=0.72
AI_USAGE_GROWTH_FACTOR=1.15
AI_PLATFORM_OVERHEAD_EUR=2.2
AI_SAFETY_BUFFER_EUR=1.4

