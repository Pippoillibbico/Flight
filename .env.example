OPPORTUNITY_AI_ENRICHMENT_DAILY_BUDGET=0

# Synthetic load/viral gate thresholds
LOAD_GATE_REQUESTS_PER_USER_FLOW=4
LOAD_GATE_SEARCHES_PER_USER_WINDOW=1
LOAD_GATE_PROVIDER_CACHE_MISS_RATIO=0.85
LOAD_GATE_PROVIDER_RETRY_FACTOR=1.1
LOAD_GATE_BACKEND_RPM_MAX=120000
LOAD_GATE_PROVIDER_RPM_MAX=30000
LOAD_GATE_PROVIDER_MONTHLY_MAX=10000000

# SLO dashboard + enforcement
SLO_WINDOW_HOURS=24
SLO_ERROR_RATE_MAX=0.01
SLO_P95_MS_MAX=800
SLO_WORKER_FAILURES_MAX=3
SLO_MIN_REQUESTS=100
SLO_REQUIRE_SAMPLE=false
SLO_INCLUDE_HEALTH_ENDPOINTS=false
SLO_EXCLUDED_ENDPOINT_PREFIXES=/health,/healthz,/api/health
SLO_WARMUP_AUTO_START_SERVER=true
SLO_WARMUP_LOCAL_PROFILE=true
SLO_WARMUP_BASE_URL=http://127.0.0.1:3000
SLO_WARMUP_ENDPOINT=/api/system/data-status
SLO_WARMUP_REQUEST_TIMEOUT_MS=1500
SLO_WARMUP_MAX_ATTEMPTS=300
SLO_WARMUP_CONCURRENCY=5
SLO_WARMUP_PAUSE_MS=25
SLO_WARMUP_READ_EVERY=20
SLO_WARMUP_ALLOW_SYNTHETIC_BACKFILL=true
SLO_WARMUP_SYNTHETIC_ENDPOINT=/api/system/data-status
SLO_WARMUP_MAX_SYNTHETIC_ROWS=2000

# Regression intelligence gates
TEST_INTELLIGENCE_SKIP_E2E=false
TEST_INTELLIGENCE_TEST_ISOLATION_NONE=false
TEST_INTELLIGENCE_ALLOW_E2E_SPAWN_EPERM_SKIP=true

# Ingestion jobs maintenance
INGESTION_JOBS_RETENTION_DAYS=30
INGESTION_JOBS_RETENTION_MAX_ROWS=5000
INGESTION_JOBS_CLEANUP_MIN_INTERVAL_MS=900000
INGESTION_JOBS_STALE_RUNNING_HOURS=6
INGESTION_JOBS_SAME_TYPE_STALE_MINUTES=60
INGESTION_JOB_OVERLAP_GUARD_MINUTES=30
INGESTION_JOBS_MAINTENANCE_CRON=*/15 * * * *
INGESTION_JOBS_MAINTENANCE_TIMEZONE=UTC

# System state report guardrails
SYSTEM_STATE_REPORT_REQUIRE_PRIMARY=false
