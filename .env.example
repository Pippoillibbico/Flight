SEARCH_PROVIDER_ROUTE_DAILY_BUDGET=180
SEARCH_PROVIDER_ROUTE_PER_MINUTE_BUDGET=14
# When true, budget checks fail open if cache backend is unavailable.
# When false (default), fail closed to avoid uncontrolled provider spend.
SEARCH_PROVIDER_BUDGET_FAIL_OPEN=false
# Max unique destinations queried live per search request (1–10)
SEARCH_PROVIDER_VALIDATION_LIMIT=5
# Search history persistence.
# Default when unset: TRUE in SQLite/dev mode (no DATABASE_URL), FALSE in Postgres/prod mode.
# Set to true to force-enable in Postgres, or false to force-disable in SQLite.
# When disabled, /api/search/history returns [] and the feature is hidden in the UI.
SEARCH_HISTORY_PERSIST_ENABLED=
DUFFEL_API_KEY=
# ── Live flight cache (Duffel offer results) ──────────────────────────────────
# TTL for successful offer responses (seconds). Default: 1800 (30 min).
# Shorter = fresher prices but more Duffel API calls and cost.
LIVE_FLIGHT_CACHE_TTL_SECONDS=1800
# TTL for empty / no-result responses (seconds). Default: 300 (5 min).
# Avoids hammering Duffel on routes with no inventory.
LIVE_FLIGHT_NEGATIVE_CACHE_TTL_SECONDS=300
# Max destinations queried in parallel per searchLiveFlights call (1–20). Default: 8.
LIVE_FLIGHT_DESTINATION_LIMIT=4
CRON_RETRY_ATTEMPTS=1
CRON_RETRY_DELAY_MS=1500
CRON_ALLOW_OVERLAP_JOBS=
SHUTDOWN_TIMEOUT_MS=12000
# ── Flight provider circuit breaker & request settings ────────────────────────
# ALLOW_STUB_PROVIDERS — load stub/mock providers for local testing. Default: false.
ALLOW_STUB_PROVIDERS=false
# Number of consecutive failures before the circuit breaker opens. Default: 3.
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
# How long (ms) the circuit stays open before retry. Default: 30000.
PROVIDER_CIRCUIT_OPEN_MS=30000
# Per-request retry attempts and timeout for live provider calls. Default: 2 / 12000.
PROVIDER_REQUEST_RETRIES=1
PROVIDER_REQUEST_TIMEOUT_MS=12000
PROVIDER_SEARCH_TIMEOUT_MS=12000
PROVIDER_SEARCH_TIMEOUT_MAX_MS=20000

