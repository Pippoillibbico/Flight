# ── Multi-source search engine ────────────────────────────────────────────────
# Set to true to enable POST /api/engine/multi-source-search.
# Requires at least one provider to be enabled and configured above.
ENABLE_MULTI_SOURCE_SEARCH=false
# Price deduplication tolerance (percent) between providers for the same fare.
# Offers within this tolerance are considered duplicates; cheapest wins.
MULTI_SOURCE_DEDUP_TOLERANCE_PCT=3
SEARCH_PROVIDER_VALIDATION_ENABLED=true
SEARCH_PROVIDER_COST_SHIELD_ENABLED=true
SEARCH_PROVIDER_GLOBAL_DAILY_BUDGET=2500
