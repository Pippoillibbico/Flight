# Max real-time detections per route per 60-second window (default: 30)
REALTIME_RATE_LIMIT_PER_ROUTE=30
# Minimum observation_count in route_baselines to trust the baseline (default: 3)
REALTIME_MIN_BASELINE_COUNT=3

